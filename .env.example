# ============================================================
# AbsensiCerdas - Environment Variables
# Copy file ini ke .env dan isi nilai yang sesuai
# Set semua variabel ini di Vercel / Railway / deployment platform
# ============================================================

# Database Configuration (Supabase PostgreSQL)
# Connect via connection pooling (untuk runtime queries)
DATABASE_URL="postgresql://[user]:[password]@[host]:6543/[db]?pgbouncer=true"

# Direct connection (untuk prisma migrate / prisma db push)
DIRECT_URL="postgresql://[user]:[password]@[host]:5432/[db]"

# JWT Secret — untuk signing auth_token cookie (gunakan string random panjang)
JWT_SECRET="ganti-dengan-secret-random-yang-panjang-min-32-karakter"

# Web Push VAPID Keys — generate dengan: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY="[public key dari generateVAPIDKeys]"
VAPID_PRIVATE_KEY="[private key dari generateVAPIDKeys]"
# Harus sama dengan VAPID_PUBLIC_KEY, dipakai di client-side (browser)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="[sama dengan VAPID_PUBLIC_KEY]"

# App Environment
NODE_ENV="production"
