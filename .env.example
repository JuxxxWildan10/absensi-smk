# ============================================================
# AbsensiCerdas - Environment Variables
# Copy file ini ke .env dan isi nilai yang sesuai
# Set semua variabel ini di Vercel / Railway / deployment platform
# ============================================================

# Database Configuration (Supabase PostgreSQL)
# Connect via connection pooling (untuk runtime queries)
DATABASE_URL="postgresql://[user]:[password]@[host]:6543/[db]?pgbouncer=true"

# Direct connection (untuk prisma migrate / prisma db push)
DIRECT_URL="postgresql://[user]:[password]@[host]:5432/[db]"

# App Environment
NODE_ENV="production"
