generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String              @id @default(uuid())
  name             String
  username         String              @unique
  password         String
  role             String
  avatar           String?
  phone            String?
  email            String?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  nisn             String?             @unique
  kelas            String?
  jurusan          String?
  faceDescriptor   String?
  parentId         String?
  isAlumni         Boolean             @default(false)
  graduationYear   Int?
  deviceId         String?
  nip              String?             @unique
  mataPelajaran    String?
  kelasWali        String?
  studentIds       String?
  waNumber         String?
  pushSubscription String?
  attendances      AttendanceRecord[]
  auditLogs        AuditLog[]
  notifications    InAppNotification[]
  permits          PermitRequest[]
}

model SchoolConfig {
  id            String @id @default(uuid())
  name          String
  address       String
  latitude      Float
  longitude     Float
  radius        Int
  checkInStart  String
  checkInEnd    String
  checkOutStart String
  checkOutEnd   String
}

model AttendanceRecord {
  id          String  @id @default(uuid())
  studentId   String
  studentName String
  kelas       String
  date        String
  status      String
  notes       String?
  checkIn     String?
  checkOut    String?
  student     User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model PermitRequest {
  id             String   @id @default(uuid())
  studentId      String
  studentName    String
  kelas          String
  type           String
  startDate      String
  endDate        String
  reason         String
  attachmentUrl  String?
  status         String
  approvedBy     String?
  approvedAt     String?
  rejectedReason String?
  createdAt      DateTime @default(now())
  student        User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model InAppNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AcademicEvent {
  id          String  @id @default(uuid())
  title       String
  startDate   String
  endDate     String
  type        String
  description String?
  createdBy   String
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  role      String
  action    String
  target    String?
  detail    String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String  @id @default(uuid())
  title       String
  content     String
  targetRoles String
  targetKelas String?
  priority    String
  publishedAt String
  expiresAt   String?
  authorId    String
  authorName  String
}

model ClassRoom {
  id   String @id @default(uuid())
  name String @unique
}
